__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
.mypy_cache/
.ruff_cache/

