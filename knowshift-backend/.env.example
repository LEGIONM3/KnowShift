# KnowShift Backend — Environment Variables
# Copy this file to .env and fill in your values.

# ── Supabase ──────────────────────────────────────────────────────────────────
# SUPABASE_URL=https://your-project.supabase.co
# ⚠️  Use the SERVICE-ROLE key (not the anon/publishable key).
#     The backend bypasses RLS — the anon key will cause 401 errors on all writes.
#     Find it: Supabase Dashboard → Project Settings → API → service_role (secret)
SUPABASE_KEY=your-supabase-service-role-key

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── Redis (Celery broker) ─────────────────────────────────────────────────────
# Local dev:      redis://localhost:6379/0
# Render managed: set automatically via render.yaml fromService binding
REDIS_URL=redis://localhost:6379/0

# ── Application ───────────────────────────────────────────────────────────────
# "development" → full error details in API responses
# "production"  → safe error messages only
ENVIRONMENT=development
